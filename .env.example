# Environment template for production deployment
# Copy this to .env and fill in your values
# NEVER commit .env to version control!

# Django settings
DEBUG=False
SECRET_KEY=your-very-long-secure-random-key-here-change-this

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (for PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/lmsdb

# AWS S3 Settings (for static files and media)
USE_S3=True
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# AWS SES (for email)
AWS_SES_REGION_NAME=us-east-1
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional: Stripe keys if using payments
STRIPE_PUBLIC_KEY=pk_live_your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here

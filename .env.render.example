# Render Environment Variables Template
# Copy these values into Render Dashboard → Environment Variables
# DO NOT commit actual .env file to Git

# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-render-dashboard
PYTHON_VERSION=3.9

# Database (Render will auto-populate if using their PostgreSQL)
DATABASE_URL=postgresql://username:password@your-render-database-host:5432/lmsdb

# Allowed Hosts
ALLOWED_HOSTS=your-app-name.onrender.com,yourdomain.com,www.yourdomain.com

# Static Files Configuration
USE_S3=False
STATIC_URL=/static/
MEDIA_URL=/media/

# Security Headers (Render handles HTTPS automatically)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Optional: AWS S3 for static/media files
# Uncomment and fill if you want to use S3 instead of local storage
# USE_S3=True
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# Optional: Email Configuration with AWS SES
# AWS_SES_REGION_NAME=us-east-1
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Optional: Stripe (if using payments app)
# STRIPE_PUBLIC_KEY=pk_live_your_stripe_key
# STRIPE_SECRET_KEY=sk_live_your_stripe_key
